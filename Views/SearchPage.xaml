<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PokemonApp.Views.SearchPage"
    BackgroundColor="{DynamicResource GlobalPageBackground}">

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor"
                    Value="{DynamicResource GlobalTextColor}" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout
        Padding="20"
        Spacing="20">

        <Label
            Text="Search Pokémon"
            FontSize="24"
            HorizontalOptions="Center" />

        <Label
            x:Name="StatusLabel"
            HorizontalOptions="Center"
            TextColor="Red" />

        <SearchBar
            x:Name="SearchEntry"
            Placeholder="Search Pokémon" />

        <Button
            Text="Search"
            Clicked="SearchButton_Clicked" />

        <Button
            Text="Toggle Theme"
            Clicked="ToggleTheme_Clicked" />

        <Label
            Text="Search Pokémon by name or Pokédex number. Use '-' for forms like mega or regional variants."
            HorizontalOptions="Center"
            FontSize="12"
            Opacity="0.7" />

    </VerticalStackLayout>

</ContentPage>