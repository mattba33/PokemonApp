<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PokemonApp.Views.MovesPage">

    <CollectionView ItemsSource="{Binding Moves}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Padding="10" Margin="5" Stroke="Gray" StrokeThickness="1">
                    <VerticalStackLayout Spacing="5">

                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18"/>

                        <HorizontalStackLayout Spacing="2.5">
                            <Label Text="Type:"/>
                            <Label Text="{Binding Type}" />

                            <Label Text="| Power:" />
                            <Label Text="{Binding DisplayPower}" />

                            <Label Text="| Accuracy:" />
                            <Label Text="{Binding DisplayAccuracy}" />

                        </HorizontalStackLayout>

                        <Label Text="{Binding Description}" LineBreakMode="WordWrap"/>

                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>