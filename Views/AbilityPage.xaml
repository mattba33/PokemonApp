<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PokemonApp.Views.AbilityPage"
    BackgroundColor="{DynamicResource GlobalPageBackground}">

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor"
                    Value="{DynamicResource GlobalTextColor}" />
        </Style>
    </ContentPage.Resources>

    <CollectionView ItemsSource="{Binding Abilities}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Padding="10" Margin="5" Stroke="Gray" StrokeThickness="1">
                    <VerticalStackLayout Spacing="5">

                        <Label Text="{Binding DisplayName}"
                               FontAttributes="Bold"
                               FontSize="18"/>

                        <Label Text="{Binding Description}"
                               LineBreakMode="WordWrap"/>

                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>